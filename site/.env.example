# Cron authentication
CRON_SECRET=your-cron-secret-here

# Admin API authentication
ADMIN_API_KEY=your-admin-key-here

# AI content generation (optional — enables content pipeline)
ANTHROPIC_API_KEY=sk-ant-xxxxx
